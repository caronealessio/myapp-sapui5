<mvc:View controllerName="fiori.app.controller.Users"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc">
  <Page title="{i18n>users_title}">
    <content>
      <Table id="tblUsers"
        items="{
          path: '/UsersView',
          parameters: {
            $orderby: 'surname asc'
          }
        }"
        growing="true">
        <headerToolbar>
          <OverflowToolbar>
            <Title text="{i18n>users_title}"
              level="H2" />
            <ToolbarSpacer />
            <SearchField width="200px"
              placeholder="{i18n>users_placeholder_search}"
              search=".onSearch" />
          </OverflowToolbar>
        </headerToolbar>

        <columns>
          <Column>
            <Text text="{i18n>common_col_name}" />
          </Column>
          <Column>
            <Text text="{i18n>common_col_surname}" />
          </Column>
          <Column>
            <Text text="{i18n>users_col_username}" />
          </Column>
          <Column>
            <Text text="{i18n>common_col_email}" />
          </Column>
          <Column>
            <Text text="{i18n>users_col_role}" />
          </Column>
          <Column>
            <Text text="{i18n>users_col_gender}" />
          </Column>
          <Column>
            <Text text="{i18n>common_col_city}" />
          </Column>
          <Column>
            <Text text="{i18n>common_col_phone}" />
          </Column>
        </columns>

        <items>
          <ColumnListItem type="Navigation"
            press=".onUserPress">
            <cells>
              <Text text="{name}" />
              <Text text="{surname}" />
              <Text text="{username}" />
              <Text text="{email}" />
              <ObjectStatus text="{role_name}"
                state="{= ${role_code} === 'admin' ? 'Warning' : 'Information'}" />
              <Text text="{gender_name}" />
              <Text text="{city}" />
              <Text text="{phone}" />
            </cells>
          </ColumnListItem>
        </items>

      </Table>
    </content>

  </Page>

</mvc:View>
